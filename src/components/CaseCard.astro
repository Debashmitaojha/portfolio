---
/**
 * CaseCard — square cover, bold italic title, plain description below.
 * Reference: the image-first "writing" cards pattern (title in italic
 * serif over a description, cover art on top) — adapted into Ink & Paper:
 * the cover is either a real screenshot (`cover` prop) or a generated
 * ink motif (CaseCover) keyed by `pattern`, never stock/AI art.
 * The whole card is one link; deeper actions (video/demo) live on the
 * case study page itself.
 */
import CaseCover from './CaseCover.astro';

interface Props {
  index: string;
  kicker: string;
  title: string;
  oneLiner: string;
  href: string;
  cover?: string;
  pattern?: 'rings' | 'dots' | 'waves';
  hasVideo?: boolean;
  hasDemo?: boolean;
}

const { index, kicker, title, oneLiner, href, cover, pattern, hasVideo, hasDemo } = Astro.props;
---

<a href={href} class="case-card">
  <div class="case-card__cover">
    {
      cover ? (
        <img src={cover} alt="" loading="lazy" />
      ) : (
        <CaseCover index={index} pattern={pattern} />
      )
    }
  </div>
  <div class="case-card__body">
    <p class="label case-card__kicker">{kicker}</p>
    <h3 class="case-card__title">{title}</h3>
    <p class="case-card__desc">{oneLiner}</p>
    {
      (hasVideo || hasDemo) && (
        <p class="label case-card__flags">
          {hasVideo && '▶ walkthrough'}
          {hasVideo && hasDemo && ' · '}
          {hasDemo && 'live demo'}
        </p>
      )
    }
  </div>
</a>

<style>
  .case-card {
    display: block;
    color: inherit;
    background: var(--paper-0);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-2);
    padding: var(--space-4);
    box-shadow: var(--shadow-paper);
    transition:
      box-shadow var(--dur-2) var(--ease-out),
      transform var(--dur-2) var(--ease-out);
  }

  .case-card:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-4px);
  }

  .case-card__cover {
    border-radius: calc(var(--radius-2) - 4px);
    overflow: hidden;
    box-shadow: var(--shadow-paper);
  }

  .case-card__cover img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-3) var(--ease-out);
  }

  .case-card:hover .case-card__cover img {
    transform: scale(1.035);
  }

  .case-card__body {
    padding: var(--space-5) var(--space-2) var(--space-2);
  }

  .case-card__kicker {
    margin-bottom: var(--space-3);
  }

  .case-card__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.35rem, 1.15rem + 0.9vw, 1.7rem);
    line-height: 1.2;
    color: var(--ink-900);
  }

  .case-card__desc {
    margin-top: var(--space-3);
    color: var(--ink-500);
    font-size: var(--text-small);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .case-card__flags {
    margin-top: var(--space-4);
    color: var(--accent-600);
  }
</style>

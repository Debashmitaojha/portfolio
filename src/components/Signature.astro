---
/**
 * Signature — the Dojha mark writes itself like Apple's "hello".
 *
 * How it works: the real calligraphy (transparent-ink PNG, generated by
 * scripts/make-signature.mjs) sits inside an SVG. An animated mask —
 * pen strokes traced along the actual writing path (verified to 99.4%
 * ink coverage by scripts/check-pen-coverage.mjs) — reveals the ink in
 * true writing order: D, then ojha + flourish, then the j-dot. A final
 * soft flood catches the last hairline slivers.
 *
 * Triggered once per visit by IntersectionObserver; static under
 * prefers-reduced-motion. To change the mark: replace the scan, rerun
 * make-signature.mjs, retrace with pen-debug.mjs + check-pen-coverage.mjs.
 */
interface Props {
  width?: string; // CSS width, default 320px
  tone?: 'ink' | 'bone'; // navy on light surfaces, bone-white on dark
}

const { width = '320px', tone = 'ink' } = Astro.props;
const src = tone === 'bone' ? '/brand/dojha-ink-bone.png' : '/brand/dojha-ink.png';
const uid = 'sig-' + Math.random().toString(36).slice(2, 8);
---

<div class="signature" style={`width: ${width}`}>
  <svg
    viewBox="0 0 635 193"
    role="img"
    aria-label="Dojha — Debashmita Ojha's handwritten signature"
  >
    <defs>
      <mask id={uid}>
        <path
          class="sig-stroke sig-stroke--d"
          d="M190,8 C 160,42 122,80 88,114 C 80,128 68,146 50,156 C 34,163 16,160 9,148 C 4,138 3,124 3,110 C 20,80 60,36 95,16 C 120,4 152,0 178,8 C 198,15 210,26 216,42 C 224,62 224,78 214,92 C 202,110 172,124 140,137 C 110,150 64,164 32,156 C 18,150 8,138 8,124 C 10,112 22,104 42,105 C 56,106 68,110 78,113"
          pathLength="1"></path>
        <path
          class="sig-stroke sig-stroke--word"
          d="M172,102 C 195,92 215,88 232,88 C 238,78 255,72 268,78 C 280,84 282,96 272,102 C 260,108 242,106 240,94 C 252,86 268,84 282,90 C 296,84 310,76 318,72 C 316,102 304,130 286,150 C 270,168 250,184 232,192 C 220,196 208,182 219,166 C 240,156 262,144 280,136 C 294,126 306,108 314,96 C 328,90 340,90 352,92 C 380,84 412,52 440,22 C 448,12 462,2 468,7 C 452,28 430,54 412,76 C 400,90 390,98 382,102 C 388,92 398,90 410,92 C 422,95 430,102 438,107 C 448,105 460,94 472,87 C 486,80 504,79 513,84 C 500,78 478,84 470,96 C 466,105 475,109 487,106 C 497,103 503,95 506,86 C 508,95 511,103 517,103 C 526,102 534,99 542,98 C 562,102 580,99 597,91 C 608,81 619,80 628,83 C 633,86 636,89 636,92"
          pathLength="1"></path>
        <circle class="sig-dot" cx="327" cy="58" r="9" fill="#fff"></circle>
        <rect class="sig-flood" x="0" y="0" width="635" height="193" fill="#fff"></rect>
      </mask>
    </defs>
    <image href={src} width="635" height="193" mask={`url(#${uid})`}></image>
  </svg>
</div>

<script>
  const marks = document.querySelectorAll('.signature');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced) {
    marks.forEach((m) => m.classList.add('is-written'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-written');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    marks.forEach((m) => io.observe(m));
  }
</script>

<style>
  .signature {
    max-width: 100%;
  }

  .signature svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Mask strokes: white = revealed. Wider than the calligraphy line so the
     reveal front stays just ahead of the ink's edge. */
  .sig-stroke {
    fill: none;
    stroke: #fff;
    stroke-width: 24;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  .sig-dot,
  .sig-flood {
    opacity: 0;
  }

  /* Writing choreography (total ~2.6s):
     D: 0 to 0.9s | word: 0.95 to 2.35s | j-dot tap: 2.4s | flood: 2.45s */
  .signature.is-written .sig-stroke--d {
    animation: sig-draw 900ms cubic-bezier(0.45, 0.05, 0.55, 0.95) 0ms forwards;
  }

  .signature.is-written .sig-stroke--word {
    animation: sig-draw 1400ms cubic-bezier(0.45, 0.05, 0.55, 0.95) 950ms forwards;
  }

  .signature.is-written .sig-dot {
    animation: sig-pop 120ms ease-out 2400ms forwards;
  }

  .signature.is-written .sig-flood {
    animation: sig-pop 350ms ease-out 2450ms forwards;
  }

  @keyframes sig-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes sig-pop {
    to {
      opacity: 1;
    }
  }

  /* Reduced motion / no-JS fallback: show the mark instantly. */
  @media (prefers-reduced-motion: reduce) {
    .sig-flood {
      opacity: 1;
    }
  }
</style>

---
/**
 * Live demo — a browser reconstruction of the retail-checkout case study's
 * "Scan and Go" flow. See src/scripts/checkout-demo.ts for the state
 * machine; this page is just the phone-frame shell it mounts into.
 */
import Base from '../layouts/Base.astro';
---

<Base
  title="Try Scan and Go — live demo — Debashmita Ojha"
  description="A browser reconstruction of the Scan and Go retail checkout flow: scan, cart, coupons, mock auth and payment, exit verification."
>
  <div class="surface-bone textured demo-page">
    <div class="container demo-page__inner">
      <p class="label">retail checkout · live demo</p>
      <h1 class="demo-page__title">Try &ldquo;Scan and Go&rdquo;</h1>
      <p class="lead demo-page__intro">
        A browser reconstruction of the flow from the case study — the same cart
        logic, coupon rules and screens. Nothing here calls a real gateway: OTP
        and card details are simulated so you can try the whole path in under a
        minute, no setup required.
      </p>
      <a class="link demo-page__back" href="/work/retail-checkout">← back to the case study</a>

      <div class="demo-stage">
        <div class="phone">
          <div class="phone__notch" aria-hidden="true"></div>
          <div class="phone__screen" id="dc-root"></div>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { mountCheckoutDemo } from '../scripts/checkout-demo';

  const root = document.getElementById('dc-root');
  if (root) mountCheckoutDemo(root);
</script>

<style>
  .demo-page {
    padding-block: var(--space-8);
    min-height: 100vh;
  }

  .demo-page__title {
    margin-top: var(--space-3);
    font-size: var(--text-h1);
  }

  .demo-page__intro {
    margin-top: var(--space-4);
    max-width: 46rem;
  }

  .demo-page__back {
    display: inline-block;
    margin-top: var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.04em;
  }

  .demo-stage {
    display: flex;
    justify-content: center;
    margin-top: var(--space-8);
  }

  /* ---- Phone frame ------------------------------------------------- */

  .phone {
    position: relative;
    width: min(390px, 100%);
    height: 780px;
    max-height: 82vh;
    background: var(--void-0);
    border-radius: 2.5rem;
    padding: 0.6rem;
    box-shadow: var(--shadow-lift);
    border: 1px solid var(--void-2);
  }

  .phone__notch {
    position: absolute;
    top: 0.6rem;
    left: 50%;
    transform: translateX(-50%);
    width: 40%;
    height: 1.6rem;
    background: var(--void-0);
    border-radius: 0 0 1rem 1rem;
    z-index: 3;
  }

  .phone__screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--paper-0);
    border-radius: 2rem;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    scrollbar-width: thin;
  }

  @media (max-width: 480px) {
    .phone {
      height: 74vh;
      border-radius: 1.6rem;
    }
    .phone__screen {
      border-radius: 1.2rem;
    }
  }
</style>

<style is:global>
  /* ---- Demo screen internals — global because content is injected via
     innerHTML by checkout-demo.ts, so scoped styles wouldn't reach it. */

  #dc-root {
    font-family: var(--font-sans);
    color: var(--ink-800);
  }

  .dc-chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: 2.2rem var(--space-4) var(--space-3);
    flex: 0 0 auto;
  }

  .dc-chrome__restart {
    background: none;
    border: none;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    color: var(--ink-500);
    padding: 0.3rem;
  }

  .dc-dots {
    display: flex;
    gap: 0.3rem;
  }

  .dc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--line-soft);
  }

  .dc-dot.is-done {
    background: var(--accent-600);
  }

  .dc-chrome__cart {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    background: var(--ink-800);
    color: var(--paper-0);
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.35rem 0.75rem;
    cursor: pointer;
  }

  .dc-chrome__spacer {
    width: 3.5rem;
  }

  .dc-body {
    flex: 1 1 auto;
    padding: 0 var(--space-4) var(--space-6);
  }

  .dc-h2 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    margin-top: 0;
  }

  .dc-h3 {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-500);
    margin-top: var(--space-5);
  }

  .dc-muted {
    color: var(--ink-500);
    font-size: 0.92rem;
    margin-top: 0.3rem;
  }

  .dc-label-text {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--ink-500);
    margin-top: var(--space-5);
  }

  /* Scan screen */
  .dc-store {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-500);
  }

  .dc-viewfinder {
    margin-top: var(--space-3);
    background: var(--void-0);
    border-radius: var(--radius-2);
    padding: var(--space-5) var(--space-4);
    text-align: center;
  }

  .dc-viewfinder__frame {
    position: relative;
    width: 100%;
    height: 96px;
    margin: 0 auto;
  }

  .dc-viewfinder__corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border: 2px solid var(--acid);
  }
  .dc-viewfinder__corner--tl { top: 0; left: 30%; border-right: none; border-bottom: none; }
  .dc-viewfinder__corner--tr { top: 0; right: 30%; border-left: none; border-bottom: none; }
  .dc-viewfinder__corner--bl { bottom: 0; left: 30%; border-right: none; border-top: none; }
  .dc-viewfinder__corner--br { bottom: 0; right: 30%; border-left: none; border-top: none; }

  .dc-viewfinder__line {
    position: absolute;
    left: 30%;
    right: 30%;
    top: 0;
    height: 2px;
    background: var(--acid);
    box-shadow: 0 0 8px var(--acid);
    animation: dc-scanline 2.2s ease-in-out infinite;
  }

  @keyframes dc-scanline {
    0%, 100% { top: 4px; }
    50% { top: 88px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dc-viewfinder__line {
      animation: none;
      top: 46px;
    }
  }

  .dc-viewfinder__hint {
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    color: var(--bone-1);
  }

  .dc-shelf {
    margin-top: var(--space-5);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .dc-shelf-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    background: var(--paper-1);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-1);
    padding: var(--space-3);
    cursor: pointer;
    text-align: left;
    transition: transform var(--dur-1) var(--ease-out), box-shadow var(--dur-1) var(--ease-out);
  }

  .dc-shelf-item:hover,
  .dc-shelf-item:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-paper);
  }

  .dc-shelf-item__emoji {
    font-size: 1.4rem;
  }

  .dc-shelf-item__name {
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .dc-shelf-item__price {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-500);
  }

  .dc-manual-toggle {
    display: block;
    margin-top: var(--space-4);
    background: none;
    border: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-500);
    cursor: pointer;
    padding: 0.2rem 0;
  }

  .dc-manual {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .dc-manual__input {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-1);
    background: var(--paper-1);
    color: var(--ink-800);
  }

  /* Buttons (demo-local, mirrors Button.astro voices) */
  .dc-btn {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.75em 1.2em;
    border-radius: var(--radius-1);
    border: 1.5px solid var(--ink-800);
    cursor: pointer;
    transition: transform var(--dur-1) var(--ease-out), opacity var(--dur-1) var(--ease-out);
  }

  .dc-btn:active {
    transform: translateY(1px);
  }

  .dc-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .dc-btn--primary {
    background: var(--ink-800);
    color: var(--paper-0);
  }

  .dc-btn--ghost {
    background: transparent;
    color: var(--ink-800);
  }

  .dc-btn--block {
    display: block;
    width: 100%;
    margin-top: var(--space-5);
    text-align: center;
  }

  /* Cart screen */
  .dc-link-back {
    background: none;
    border: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-500);
    cursor: pointer;
    padding: 0;
    margin-top: var(--space-3);
  }

  .dc-cart-list {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: grid;
    gap: var(--space-3);
  }

  .dc-cart-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--line-soft);
  }

  .dc-cart-row__name {
    font-size: 0.88rem;
  }

  .dc-cart-row__price {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .dc-cart-empty {
    color: var(--ink-500);
    font-size: 0.9rem;
    padding: var(--space-4) 0;
  }

  .dc-stepper {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
  }

  .dc-stepper button {
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    border: 1px solid var(--line-soft);
    background: var(--paper-1);
    cursor: pointer;
    line-height: 1;
  }

  .dc-coupons {
    display: grid;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .dc-coupon {
    display: grid;
    text-align: left;
    background: var(--paper-1);
    border: 1.5px dashed var(--line-soft);
    border-radius: var(--radius-1);
    padding: var(--space-3);
    cursor: pointer;
  }

  .dc-coupon.is-active {
    border-style: solid;
    border-color: var(--accent-600);
    background: var(--accent-100);
  }

  .dc-coupon.is-disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .dc-coupon__code {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
  }

  .dc-coupon__label {
    font-size: 0.82rem;
  }

  .dc-coupon__meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-500);
    margin-top: 0.2rem;
  }

  .dc-bill {
    margin-top: var(--space-5);
    border-top: 1px solid var(--line-soft);
    padding-top: var(--space-3);
  }

  .dc-bill div {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    padding: 0.2rem 0;
  }

  .dc-bill dt {
    color: var(--ink-500);
  }

  .dc-bill__total {
    font-weight: 700;
    font-size: 1rem !important;
    margin-top: 0.3rem;
    padding-top: 0.4rem !important;
    border-top: 1px solid var(--line-soft);
  }

  .dc-bill--compact {
    border-top: none;
    padding-top: 0;
  }

  /* Auth screen */
  .dc-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-500);
    margin-top: var(--space-4);
  }

  .dc-input {
    width: 100%;
    margin-top: 0.4rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-1);
    background: var(--paper-1);
    color: var(--ink-800);
  }

  .dc-input--otp {
    letter-spacing: 0.5rem;
    font-family: var(--font-mono);
    text-align: center;
    width: 8rem;
  }

  .dc-hint {
    font-size: 0.78rem;
    color: var(--ink-500);
    margin-top: 0.3rem;
  }

  .dc-otp-block {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px dashed var(--line-soft);
  }

  .dc-recaptcha {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-4);
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-1);
    font-size: 0.85rem;
    width: fit-content;
  }

  /* Pay screen */
  .dc-pay__ribbon {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    background: var(--blood);
    color: var(--paper-0);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-1);
    transform: rotate(-2deg);
  }

  .dc-card {
    margin-top: var(--space-5);
    background: linear-gradient(135deg, var(--ink-800), var(--ink-600));
    color: var(--paper-0);
    border-radius: var(--radius-2);
    padding: var(--space-5);
  }

  .dc-card__bank {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    opacity: 0.8;
  }

  .dc-card__number {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    margin-top: var(--space-4);
    letter-spacing: 0.05em;
  }

  .dc-card__row {
    display: flex;
    justify-content: space-between;
    font-size: 0.68rem;
    margin-top: var(--space-4);
    opacity: 0.85;
  }

  /* Verify + done screens */
  .dc-qr {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 192px;
    height: 192px;
    margin: var(--space-5) auto 0;
    background: var(--paper-1);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-2);
  }

  .dc-verify-meta {
    margin-top: var(--space-5);
    display: grid;
    gap: 0.4rem;
  }

  .dc-verify-meta div {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .dc-verify-meta dt {
    color: var(--ink-500);
  }

  .dc-done__check {
    font-size: 2.2rem;
    color: var(--accent-600);
    margin: 0;
  }

  .dc-ratings {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .dc-rating {
    font-size: 0.85rem;
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line-soft);
    background: var(--paper-1);
    cursor: pointer;
  }

  .dc-rating.is-active {
    border-color: var(--accent-600);
    background: var(--accent-100);
  }

  /* Toast + sticky cart bar */
  .dc-toast {
    position: sticky;
    bottom: 0.6rem;
    margin: 0 var(--space-4);
    background: var(--ink-800);
    color: var(--paper-0);
    font-size: 0.8rem;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-1);
    text-align: center;
  }

  .dc-cartbar {
    position: sticky;
    bottom: 0;
    flex: 0 0 auto;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    background: var(--acid);
    color: var(--ink-900);
    border: none;
    padding: 0.9rem;
    cursor: pointer;
  }
</style>
